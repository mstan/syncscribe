# ============================================
# SyncScribe - Environment Variables
# ============================================

# ---- OpenAI (REQUIRED) ----
# Used for Whisper API transcription and GPT translation
OPENAI_API_KEY=your_openai_api_key_here

# ---- Server ----
PORT=3000
NODE_ENV=development

# ---- Database (Postgres) ----
# Option 1: Connection URL
DATABASE_URL=postgresql://syncscribe:password@localhost:5432/syncscribe
# Option 2: Individual vars (used if DATABASE_URL is not set)
# PG_HOST=localhost
# PG_PORT=5432
# PG_USER=syncscribe
# PG_PASSWORD=password
# PG_DATABASE=syncscribe

# ---- Authentication ----
# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your_google_client_id_here
# JWT secret for session tokens
JWT_SECRET=change_this_to_a_random_secret_string

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ---- Cloudflare R2 (S3-compatible) ----
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET=syncscribe

# ---- Rate Limiting ----
MAX_CONCURRENT_JOBS=3
# MAX_MINUTES_PER_JOB=180

# ---- CORS ----
# Comma-separated list of allowed origins (for production)
# CORS_ORIGINS=https://yourdomain.com

# ---- Debug Logging (OPTIONAL) ----
# DEBUG=SubtitleGenerator:*
